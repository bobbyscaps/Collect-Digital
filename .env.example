# Privy app ID (public client identifier, safe to expose in the browser bundle).
# Get yours from the Privy Dashboard: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Admin allowlist for /admin/score-lab, as a comma-separated list of Privy user
# IDs (DIDs, e.g. did:privy:abc123). Not a secret — server-side write actions are
# enforced by verifying the Privy access token against Privy's public JWKS.
# If left empty: the Score Lab is OPEN in development and LOCKED in production.
# To find your DID, log in and open /admin/score-lab; it is shown on the
# "Not authorized" screen.
NEXT_PUBLIC_ADMIN_ALLOWLIST=

# Alchemy API key (server-side). Enables REAL collector ratings derived from
# on-chain wallet history for address profiles (/profile/0x...) and
# /api/wallet/[address]/collector-rating. Without it, collector scores fall back
# to synthetic per-username values. Get one at https://dashboard.alchemy.com
ALCHEMY_API_KEY=
